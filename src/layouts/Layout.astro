---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = "Gabriela Biscáro — Illustrator" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-beige font-rubik m-0 p-0 overflow-x-hidden">
    <slot />
  </body>
</html>
