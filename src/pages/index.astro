---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.order - b.data.order);

const reader = createReader(process.cwd(), keystaticConfig);
const workPageData = await reader.singletons.workPage.read().catch(() => null);
const heroImage = workPageData?.heroImage ?? null;

const imgLogo = "/images/logo.svg";
const imgHeroMask = "/images/Hero-Mask.png";
const imgLongArrowRight = "/images/long-arrow-right.svg";
const imgFlorRosa = "/images/Flor-Vermelha-Pequena.svg";
---

<Layout title="Work — Gabriela Biscáro">
  <div class="w-full overflow-x-hidden">

    <!-- Hero -->
    <div class="relative w-full h-[300px] lg:h-[700px]">
      <!-- Background color always visible (shows through transparent PNGs) -->
      <div class="absolute inset-0" style={`background-color: #f1e6b7; mask-image: url('${imgHeroMask}'); mask-size: cover; mask-repeat: no-repeat; -webkit-mask-image: url('${imgHeroMask}'); -webkit-mask-size: cover; -webkit-mask-repeat: no-repeat;`}></div>
      <!-- Hero image layered on top (transparent areas reveal the background) -->
      {heroImage && (
        <img src={heroImage} alt="" class="absolute inset-0 w-full h-full object-cover" style={`mask-image: url('${imgHeroMask}'); mask-size: cover; mask-repeat: no-repeat; -webkit-mask-image: url('${imgHeroMask}'); -webkit-mask-size: cover; -webkit-mask-repeat: no-repeat;`} />
      )}
      <div class="max-w-[1440px] mx-auto">
        <nav class="relative z-10 flex items-center justify-between px-6 pt-6 lg:px-[141px] lg:pt-[35px]">
          <a href="/"><img src={imgLogo} alt="Logo" style="width:40px;height:49px;object-fit:contain;" /></a>
          <div class="hidden lg:flex gap-[38px] items-center">
            <div class="flex flex-col items-start">
              <a href="/" class="font-bold text-[16px] text-pink uppercase">Work</a>
              <img src="/images/wave-work.svg" alt="" class="mt-1 w-full" />
            </div>
            <a href="/personal-work" class="font-bold text-[16px] text-pink uppercase">Personal Work</a>
            <a href="/about" class="font-bold text-[16px] text-pink uppercase">About</a>
          </div>
          <button id="nav-toggle" class="lg:hidden text-pink p-2" aria-label="Open menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
        </nav>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-50 bg-bordoux flex-col items-center justify-center gap-10">
      <button id="nav-close" class="absolute top-6 right-6 text-beige text-[32px] leading-none font-bold">✕</button>
      <a href="/" class="font-bold text-[24px] text-beige uppercase">Work</a>
      <a href="/personal-work" class="font-bold text-[24px] text-beige uppercase">Personal Work</a>
      <a href="/about" class="font-bold text-[24px] text-beige uppercase">About</a>
    </div>

    <!-- Apresentação + Grids -->
    <div class="max-w-[1440px] mx-auto">
    <div class="px-6 mt-12 mb-8 lg:px-[141px] lg:mt-[139px] lg:mb-[79px]">
      <p class="font-normal text-[16px] text-gray mb-4">Oh, hello everyone!</p>
      <div class="font-extrabold text-[28px] lg:text-[48px] text-bordoux leading-tight">
        <p>My name is Gabriela Biscáro</p>
        <p>and I'm Brazilian Illustrator</p>
      </div>
    </div>

    <!-- Grid mobile -->
    <div class="lg:hidden px-6 flex flex-col gap-4 mb-12">
      {sorted.map((p) => (
        <a href={`/work/${p.id}`} class="group relative rounded-[12px] overflow-hidden w-full h-[280px] block">
          <img src={p.data.thumbnail} alt={p.data.title} class="absolute inset-0 w-full h-full object-cover" />
          <div class="absolute inset-0 bg-pink mix-blend-multiply opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-6">
            <p class="font-extrabold text-[20px] text-bordoux text-center">{p.data.title}</p>
          </div>
        </a>
      ))}
    </div>

    <!-- Grid desktop -->
    <div class="hidden lg:flex lg:flex-col px-[141px] gap-[16px]">

      <!-- Linha 1 -->
      <div class="flex gap-[16px]">
        {sorted.filter((_, i) => i === 0).map((p) => (
          <a href={`/work/${p.id}`} class="group relative rounded-[12px] overflow-hidden w-[454px] h-[570px] shrink-0 block">
            <img src={p.data.thumbnail} alt={p.data.title} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-pink mix-blend-multiply opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-center p-[40px]">
              <p class="font-extrabold text-[24px] text-bordoux text-center w-full">{p.data.title}</p>
              <img src={imgLongArrowRight} alt="" class="w-[94px] h-[58px] absolute bottom-[40px] right-[40px]" />
            </div>
          </a>
        ))}
        {sorted.filter((_, i) => i === 1).map((p) => (
          <a href={`/work/${p.id}`} class="group relative rounded-[12px] overflow-hidden w-[688px] h-[570px] shrink-0 block">
            <img src={p.data.thumbnail} alt={p.data.title} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-pink mix-blend-multiply opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-center p-[40px]">
              <p class="font-extrabold text-[24px] text-bordoux text-center w-full">{p.data.title}</p>
              <img src={imgLongArrowRight} alt="" class="w-[94px] h-[58px] absolute bottom-[40px] right-[40px]" />
            </div>
          </a>
        ))}
      </div>

      <!-- Linha 2 -->
      <div class="flex gap-[58px] items-center">
        {sorted.filter((_, i) => i === 2).map((p) => (
          <a href={`/work/${p.id}`} class="group relative rounded-[12px] overflow-hidden w-[570px] h-[570px] shrink-0 block">
            <img src={p.data.thumbnail} alt={p.data.title} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-pink mix-blend-multiply opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-center p-[40px]">
              <p class="font-extrabold text-[24px] text-bordoux text-center w-full">{p.data.title}</p>
              <img src={imgLongArrowRight} alt="" class="w-[94px] h-[58px] absolute bottom-[40px] right-[40px]" />
            </div>
          </a>
        ))}
        <div class="flex flex-col gap-[24px] w-[529px]">
          <img src={imgFlorRosa} alt="" class="w-[96px] h-[96px]" />
          <p class="font-extrabold text-[48px] text-bordoux leading-tight">My illustrations vary between analog and digital painting.</p>
          <p class="font-normal text-[24px] text-gray">I love exploring with different kinds of materials: gouache, watercolor, acrylic paint, colored pencil, markers, collage.</p>
        </div>
      </div>

      <!-- Linha 3 -->
      <div class="flex gap-[16px]">
        {sorted.filter((_, i) => i === 3).map((p) => (
          <a href={`/work/${p.id}`} class="group relative rounded-[12px] overflow-hidden w-[688px] h-[570px] shrink-0 block">
            <img src={p.data.thumbnail} alt={p.data.title} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-pink mix-blend-multiply opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-center p-[40px]">
              <p class="font-extrabold text-[24px] text-bordoux text-center w-full">{p.data.title}</p>
              <img src={imgLongArrowRight} alt="" class="w-[94px] h-[58px] absolute bottom-[40px] right-[40px]" />
            </div>
          </a>
        ))}
        {sorted.filter((_, i) => i === 4).map((p) => (
          <a href={`/work/${p.id}`} class="group relative rounded-[12px] overflow-hidden w-[454px] h-[570px] shrink-0 block">
            <img src={p.data.thumbnail} alt={p.data.title} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-pink mix-blend-multiply opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-center p-[40px]">
              <p class="font-extrabold text-[24px] text-bordoux text-center w-full">{p.data.title}</p>
              <img src={imgLongArrowRight} alt="" class="w-[94px] h-[58px] absolute bottom-[40px] right-[40px]" />
            </div>
          </a>
        ))}
      </div>

      <!-- Linha 4 -->
      <div class="flex gap-[17px]">
        {sorted.filter((_, i) => i === 5).map((p) => (
          <a href={`/work/${p.id}`} class="group relative rounded-[12px] overflow-hidden w-[570px] h-[570px] shrink-0 block">
            <img src={p.data.thumbnail} alt={p.data.title} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-pink mix-blend-multiply opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-center p-[40px]">
              <p class="font-extrabold text-[24px] text-bordoux text-center w-full">{p.data.title}</p>
              <img src={imgLongArrowRight} alt="" class="w-[94px] h-[58px] absolute bottom-[40px] right-[40px]" />
            </div>
          </a>
        ))}
        {sorted.filter((_, i) => i === 6).map((p) => (
          <a href={`/work/${p.id}`} class="group relative rounded-[12px] overflow-hidden w-[570px] h-[570px] shrink-0 block">
            <img src={p.data.thumbnail} alt={p.data.title} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-pink mix-blend-multiply opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-center p-[40px]">
              <p class="font-extrabold text-[24px] text-bordoux text-center w-full">{p.data.title}</p>
              <img src={imgLongArrowRight} alt="" class="w-[94px] h-[58px] absolute bottom-[40px] right-[40px]" />
            </div>
          </a>
        ))}
      </div>

    </div>
    </div><!-- end max-w content -->

    <!-- Footer -->
    <footer class="relative w-full overflow-hidden mt-12 lg:mt-[79px] lg:h-[968px]">
      <img src="/images/footer-background.png" alt="" class="absolute inset-0 w-full h-full object-cover" />
      <div class="relative max-w-[1440px] mx-auto h-full">
        <img src="/images/arco.svg" alt="" class="hidden lg:block absolute top-[74px] left-[200px] w-[175px] h-[172px] -rotate-[165deg]" />
        <img src="/images/arco.svg" alt="" class="hidden lg:block absolute top-[535px] left-[600px] w-[175px] h-[172px]" />
        <img src="/images/Flor-Rosa.svg" alt="" class="hidden lg:block absolute top-[473px] left-0 w-[308px] h-[308px] -scale-y-100" />
        <img src="/images/Flor-Vermelha.svg" alt="" class="hidden lg:block absolute top-[-154px] left-[564px] w-[308px] h-[308px]" />
        <img src="/images/Flor-Roxa.svg" alt="" class="hidden lg:block absolute top-[664px] left-[1063px] w-[218px] h-[162px]" />
        <img src="/images/Estrelinha-vermelha.svg" alt="" class="hidden lg:block absolute top-[454px] left-[791px] w-[213px] h-[230px] rotate-[-16.12deg]" />
        <img src="/images/Estrelinha-amarela.svg" alt="" class="hidden lg:block absolute top-[20px] left-[1190px] w-[213px] h-[230px] rotate-[-16.12deg]" />
        <img src="/images/Bonequinho-azul.svg" alt="" class="hidden lg:block absolute top-[233px] left-[907px] w-[361px] h-[327px]" />
        <img src="/images/Bonequinho-verde.svg" alt="" class="hidden lg:block absolute top-[824px] left-[590px] w-[292px] h-[292px]" />
        <div class="relative lg:absolute lg:top-1/2 lg:-translate-y-1/2 lg:left-[156px] flex flex-col gap-6 lg:gap-[24px] w-full lg:w-[489px] px-6 py-12 lg:px-0 lg:py-0">
          <div class="flex flex-col gap-3 lg:gap-[12px] text-beige">
            <p class="font-extrabold text-[32px] lg:text-[48px]">Don't be shy, say hi!</p>
            <p class="font-normal text-[16px]">You can contact me through e-mail or my social media below:</p>
          </div>
          <div class="flex gap-[12px] items-center flex-wrap">
            <a href="mailto:gabrielasbiscaro@gmail.com" class="backdrop-blur-sm bg-white/10 border border-white/40 rounded-[96px] px-[10px] py-[10px] font-bold text-[16px] text-beige underline whitespace-nowrap">gabrielasbiscaro@gmail.com</a>
            <a href="https://www.instagram.com/gabiscaroo_/" target="_blank" class="backdrop-blur-sm bg-white/10 border border-white/40 rounded-[96px] px-[10px] py-[10px] font-bold text-[16px] text-beige underline">Instagram</a>
            <a href="https://www.linkedin.com/in/gabriela-bisc%C3%A1ro/" target="_blank" class="backdrop-blur-sm bg-white/10 border border-white/40 rounded-[96px] px-[10px] py-[10px] font-bold text-[16px] text-beige underline">LinkedIn</a>
          </div>
        </div>
      </div>
    </footer>

  </div>
</Layout>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const close = document.getElementById('nav-close');
  toggle?.addEventListener('click', () => { menu?.classList.remove('hidden'); menu?.classList.add('flex'); });
  close?.addEventListener('click', () => { menu?.classList.add('hidden'); menu?.classList.remove('flex'); });
</script>
